@using ElementorBuilder.Models
@using ElementorBuilder.Options
@{
    var options = (ElementorBuilderOptions)ViewBag.Options!;
    var contentFieldId = Model.ContentFieldId ?? options.ContentFieldId;
    var draftKey = Model.DraftStorageKey ?? options.DraftStorageKey;
}

<link rel="stylesheet" href="@($"~{options.CssPath}")" asp-append-version="true" />
<link rel="stylesheet" href="@($"~{options.ContentCssPath}")" asp-append-version="true" />
<link rel="stylesheet" href="@($"~{options.FontAwesomePath}")" asp-append-version="true" />

<div class="elementor-editor-host">
<div class="elementor-toolbar">
    <div class="elementor-toolbar-left">
        <button type="button" class="elementor-toolbar-btn" data-action="add-section">
            <i class="fas fa-plus"></i>
            افزودن بخش
        </button>
        <button type="button" class="elementor-toolbar-btn" data-action="undo" title="بازگشت (Ctrl+Z)">
            <i class="fas fa-undo"></i>
        </button>
        <button type="button" class="elementor-toolbar-btn" data-action="redo" title="انجام مجدد (Ctrl+Shift+Z)">
            <i class="fas fa-redo"></i>
        </button>
        <button type="button" class="elementor-toolbar-btn" data-action="clear">
            <i class="fas fa-eraser"></i>
            پاک کردن همه
        </button>
        <button type="button" class="elementor-toolbar-btn elementor-toolbar-btn-fullscreen" data-action="fullscreen" title="حالت تمام‌صفحه (Esc برای خروج)">
            <i class="fas fa-expand"></i>
            <span class="elementor-fullscreen-label">تمام‌صفحه</span>
        </button>
    </div>

    <div class="elementor-toolbar-right">
        <button type="button" class="elementor-toolbar-btn elementor-toolbar-btn-save primary elementor-fullscreen-only" data-action="submit-form" title="ذخیره">
            <i class="fas fa-save"></i>
            ذخیره
        </button>
        <div class="elementor-device-buttons">
            <button type="button" class="elementor-device-btn active" data-device="desktop" title="دسکتاپ">
                <i class="fas fa-desktop"></i>
            </button>
            <button type="button" class="elementor-device-btn" data-device="tablet" title="تبلت">
                <i class="fas fa-tablet-alt"></i>
            </button>
            <button type="button" class="elementor-device-btn" data-device="mobile" title="موبایل">
                <i class="fas fa-mobile-alt"></i>
            </button>
        </div>

        <button type="button" class="elementor-toolbar-btn" data-action="preview">
            <i class="fas fa-eye"></i>
            پیش‌نمایش
        </button>

        @foreach (var btn in Model.ExtraToolbarButtons)
        {
            if (!string.IsNullOrEmpty(btn.Href))
            {
                <a href="@btn.Href" class="elementor-toolbar-btn@(btn.Primary ? " primary" : "")" title="@btn.Title">
                    <i class="@btn.Icon"></i>
                    @btn.Label
                </a>
            }
            else
            {
                <button type="button"
                        class="elementor-toolbar-btn@(btn.Primary ? " primary" : "")"
                        title="@btn.Title"
                        onclick="@btn.OnClick">
                    <i class="@btn.Icon"></i>
                    @btn.Label
                </button>
            }
        }

        <a href="@Model.CancelUrl" class="elementor-toolbar-btn">
            <i class="fas fa-times"></i>
            انصراف
        </a>
    </div>
</div>

<div class="elementor-editor-wrapper">
    <div class="elementor-panel">
        <div class="elementor-panel-view elementor-panel-view-widgets" data-panel-view="widgets">
        <div class="elementor-panel-header">
            <h3>
                <i class="fas fa-puzzle-piece"></i>
                ویجت‌ها و المان‌ها
            </h3>
        </div>

        <div class="elementor-panel-tabs">
            <button type="button" class="elementor-panel-tab active" data-tab="widgets">
                <i class="fas fa-th-large"></i>
                ویجت‌ها
            </button>
            <button type="button" class="elementor-panel-tab" data-tab="templates">
                <i class="fas fa-layer-group"></i>
                قالب‌ها
            </button>
        </div>

        <div class="elementor-panel-content">
            <div class="elementor-panel-widgets">
                <div class="elementor-panel-block">
                    <h4 class="elementor-panel-block-title"><i class="fas fa-th-large"></i> چیدمان ستون‌ها</h4>
                    <div class="elementor-layout-presets-grid elementor-panel-grid"></div>
                </div>
                <div class="elementor-panel-block">
                    <h4 class="elementor-panel-block-title"><i class="fas fa-puzzle-piece"></i> ویجت‌ها</h4>
                    <div class="elementor-widgets-list elementor-panel-grid"></div>
                </div>
            </div>
            <div class="elementor-panel-templates elementor-panel-hidden">
                <div class="elementor-panel-block">
                    <h4 class="elementor-panel-block-title"><i class="fas fa-layer-group"></i> بخش‌های آماده</h4>
                    <div class="elementor-section-templates-list"></div>
                </div>
            </div>
        </div>
        </div>

        <div class="elementor-panel-view elementor-panel-view-settings elementor-panel-hidden" data-panel-view="settings">
            <div class="elementor-settings-header">
                <button type="button" class="elementor-settings-back" title="بازگشت به ویجت‌ها">
                    <i class="fas fa-arrow-right"></i>
                </button>
                <div class="elementor-settings-header-text">
                    <h4>تنظیمات المان</h4>
                    <span class="elementor-settings-subtitle"></span>
                </div>
            </div>
            <div class="elementor-settings-content">
                <p class="elementor-settings-empty">
                    <i class="fas fa-mouse-pointer"></i>
                    یک بخش، ستون یا ویجت را از بوم انتخاب کنید
                </p>
            </div>
        </div>
    </div>

    <div class="elementor-canvas">
        <button type="button" class="elementor-toggle-panel" title="پنهان/نمایش پنل">
            <i class="fas fa-bars"></i>
        </button>

        <div class="elementor-canvas-inner"
             data-content-field-id="@contentFieldId"
             data-upload-url="@options.UploadUrl"
             data-delete-url="@options.DeleteUrl"
             data-draft-key="@draftKey"
             data-css-path="@options.CssPath"
             data-content-css-path="@options.ContentCssPath"
             data-font-awesome-path="@options.FontAwesomePath"
             data-max-upload-mb="@options.MaxUploadSizeMb">
            <div class="elementor-empty-state">
                <i class="fas fa-layer-group"></i>
                <h3>صفحه خالی است</h3>
                <p>برای شروع، یک بخش جدید اضافه کنید یا ویجت‌ها را بکشید و رها کنید</p>
            </div>
        </div>
    </div>
</div>
</div>

<script>
window.ElementorBuilderConfig = {
    contentFieldId: '@contentFieldId',
    uploadUrl: '@options.UploadUrl',
    deleteUrl: '@options.DeleteUrl',
    draftKey: '@draftKey',
    cssPath: '@options.CssPath',
    contentCssPath: '@options.ContentCssPath',
    fontAwesomePath: '@options.FontAwesomePath',
    maxUploadSizeMb: @options.MaxUploadSizeMb
};
</script>
<script src="@($"~{options.JsPath}")" asp-append-version="true"></script>
