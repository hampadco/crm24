@model ContentDetailRelatedSectionsModel

<aside class="taben-content-detail__aside" aria-label="@Model.IndexActionLabel پیشنهادی">
    <partial name="_ContentDetailSidebarPanel"
             model="@(Model.RelatedTitle, Model.RelatedIcon, Model.ControllerName, Model.DetailRouteName, Model.Related)" />
    <partial name="_ContentDetailSidebarPanel"
             model="@(Model.LatestTitle, Model.LatestIcon, Model.ControllerName, Model.DetailRouteName, Model.Latest)" />

    <div class="taben-detail-aside-foot">
        <a asp-controller="@Model.ControllerName" asp-action="Index" class="taben-detail-aside-all">
            مشاهده همه @Model.IndexActionLabel
            <i class="fas fa-chevron-left" aria-hidden="true"></i>
        </a>
    </div>
</aside>
