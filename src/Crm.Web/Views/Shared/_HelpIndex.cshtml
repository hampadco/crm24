@model Crm.Web.Models.Help.HelpIndexViewModel

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h4 class="mb-0"><i class="bx bx-book-open text-primary me-1"></i> @Model.Title</h4>
</div>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <div class="card bg-label-primary mb-4">
        <div class="card-body">
            <p class="mb-0">@Model.Description</p>
        </div>
    </div>
}

<div class="card mb-4">
    <div class="card-body py-3">
        <div class="input-group">
            <span class="input-group-text"><i class="bx bx-search"></i></span>
            <input type="text" id="helpSearch" class="form-control" placeholder="جستجو در موضوعات آموزش…" />
        </div>
    </div>
</div>

<div class="row g-3" id="helpTopics">
    @foreach (var topic in Model.Topics)
    {
        <div class="col-sm-6 col-lg-4 help-topic-card" data-title="@topic.Title @topic.Summary">
            <a href="@Model.BaseUrl/@topic.Slug" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="avatar mb-3">
                            <span class="avatar-initial rounded bg-label-primary"><i class="bx @topic.Icon"></i></span>
                        </div>
                        <h5 class="mb-1">@topic.Title</h5>
                        <p class="text-muted small mb-0">@topic.Summary</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var input = document.getElementById('helpSearch');
        if (!input) return;
        input.addEventListener('input', function () {
            var term = input.value.trim();
            document.querySelectorAll('.help-topic-card').forEach(function (card) {
                card.style.display = !term || (card.dataset.title || '').indexOf(term) !== -1 ? '' : 'none';
            });
        });
    });
</script>
