@using System.Text.Json
@using Crm.Core.Entities
@model Survey
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title</title>
    <link rel="stylesheet" href="/panel-assets/vendor/css/rtl/core.css" />
    <link rel="stylesheet" href="/panel-assets/vendor/css/rtl/theme-default.css" />
    <style>body { background: transparent; padding: 1rem; }</style>
</head>
<body>
    <div class="card mx-auto" style="max-width:640px">
        <div class="card-body">
            <h5 class="mb-1">@Model.Title</h5>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="text-muted">@Model.Description</p>
            }

            @if (ViewBag.Success is string success)
            {
                <div class="alert alert-success mt-3">@success</div>
            }
            else
            {
                @if (ViewBag.Error is string error)
                {
                    <div class="alert alert-danger mt-3">@error</div>
                }
                <form method="post" class="mt-3">
                    <div class="row g-2 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">نام شما</label>
                            <input type="text" name="respondentName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">شماره تماس</label>
                            <input type="text" name="respondentPhone" class="form-control" dir="ltr" />
                        </div>
                    </div>

                    @foreach (var question in Model.Questions)
                    {
                        var options = JsonSerializer.Deserialize<List<string>>(question.OptionsJson) ?? new List<string>();
                        <div class="mb-4">
                            <label class="form-label fw-bold">@question.Text</label>
                            @switch (question.Type)
                            {
                                case SurveyQuestionType.Text:
                                    <textarea name="q_@question.Id" class="form-control" rows="2"></textarea>
                                    break;
                                case SurveyQuestionType.Scale:
                                    <div class="d-flex gap-3 flex-wrap">
                                        @for (var score = 1; score <= 5; score++)
                                        {
                                            <label class="form-check">
                                                <input type="radio" name="q_@question.Id" value="@score" class="form-check-input" />
                                                <span class="form-check-label">@score</span>
                                            </label>
                                        }
                                    </div>
                                    break;
                                case SurveyQuestionType.SingleChoice:
                                    @foreach (var option in options)
                                    {
                                        <label class="form-check">
                                            <input type="radio" name="q_@question.Id" value="@option" class="form-check-input" />
                                            <span class="form-check-label">@option</span>
                                        </label>
                                    }
                                    break;
                                case SurveyQuestionType.MultiChoice:
                                    @foreach (var option in options)
                                    {
                                        <label class="form-check">
                                            <input type="checkbox" name="q_@question.Id" value="@option" class="form-check-input" />
                                            <span class="form-check-label">@option</span>
                                        </label>
                                    }
                                    break;
                            }
                        </div>
                    }

                    <button type="submit" class="btn btn-primary w-100">ثبت پاسخ</button>
                </form>
            }
        </div>
    </div>
</body>
</html>
