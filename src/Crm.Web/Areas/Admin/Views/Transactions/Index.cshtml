@using Crm.Web.Models.Admin
@model PagedList<PlatformTransactionRow>
@{
    ViewData["Title"] = "تراکنش‌ها";
    var listQuery = ViewBag.ListQuery as PlatformListQuery ?? new PlatformListQuery();
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h4 class="mb-0">
        <i class="bx bx-money text-primary me-1"></i>
        @ViewData["Title"]
        <span class="badge bg-label-secondary rounded-pill align-middle">@Model.TotalCount.ToFa()</span>
    </h4>
</div>

<partial name="_AdminAlerts" />

<div class="card">
    <div class="card-header pb-0">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-md-8">
                    <div class="input-group">
                        <input type="text" name="q" value="@listQuery.Q" class="form-control" placeholder="جستجو بر اساس نام یا شناسه مشتری..." />
                        <button type="submit" class="btn btn-outline-primary"><i class="bx bx-search"></i></button>
                    </div>
                </div>
            </form>
            @if (Model.TotalCount > 0)
            {
                <partial name="_AdminListMeta" model="Model" />
            }
        </div>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>تاریخ</th>
                    <th>مشتری</th>
                    <th>مبلغ</th>
                    <th>روش</th>
                    <th>وضعیت</th>
                    <th>پیگیری</th>
                    <th>توضیح</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-5">تراکنشی یافت نشد.</td></tr>
                }
                @foreach (var row in Model.Items)
                {
                    <tr>
                        <td>@PersianDateHelper.ToJalaliDateTime(row.AtUtc)</td>
                        <td><a asp-controller="Tenants" asp-action="Details" asp-route-id="@row.TenantId">@row.TenantName</a></td>
                        <td>@row.Amount.ToString("N0") تومان</td>
                        <td>
                            @if (row.Source == "gateway")
                            {
                                <span class="badge bg-primary">درگاه</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@row.Method</span>
                            }
                        </td>
                        <td>
                            @switch (row.Status)
                            {
                                case "paid": <span class="badge bg-success">موفق</span>; break;
                                case "pending": <span class="badge bg-warning text-dark">در انتظار</span>; break;
                                case "failed": <span class="badge bg-danger">ناموفق</span>; break;
                                default: <span class="badge bg-secondary">@row.Status</span>; break;
                            }
                        </td>
                        <td dir="ltr" class="small">@(row.Reference ?? "—")</td>
                        <td class="small">@(row.Description ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            <partial name="_AdminPagination" model="Model" />
        </div>
    }
</div>
