@using Crm.Web.Models.Admin
@model List<PlatformTransactionRow>
@{
    ViewData["Title"] = "تراکنش‌ها";
}

<div class="admin-topbar">
    <h1 class="admin-page-title">@ViewData["Title"]</h1>
</div>

<partial name="_AdminAlerts" />

<div class="admin-card">
    <div class="admin-card-header">
        <form method="get" class="row g-2 align-items-center w-100">
            <div class="col-md-8">
                <input type="text" name="q" value="@ViewData["Search"]" class="form-control form-control-sm" placeholder="جستجو بر اساس نام یا شناسه مشتری..." />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-sm btn-primary w-100">جستجو</button>
            </div>
        </form>
    </div>
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>تاریخ</th>
                    <th>مشتری</th>
                    <th>مبلغ</th>
                    <th>روش</th>
                    <th>وضعیت</th>
                    <th>پیگیری</th>
                    <th>توضیح</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">تراکنشی یافت نشد.</td></tr>
                }
                @foreach (var row in Model)
                {
                    <tr>
                        <td>@PersianDateHelper.ToJalaliDateTime(row.AtUtc)</td>
                        <td><a asp-controller="Tenants" asp-action="Details" asp-route-id="@row.TenantId">@row.TenantName</a></td>
                        <td>@row.Amount.ToString("N0") تومان</td>
                        <td>
                            @if (row.Source == "gateway")
                            {
                                <span class="badge bg-primary">درگاه</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@row.Method</span>
                            }
                        </td>
                        <td>
                            @switch (row.Status)
                            {
                                case "paid": <span class="badge bg-success">موفق</span>; break;
                                case "pending": <span class="badge bg-warning text-dark">در انتظار</span>; break;
                                case "failed": <span class="badge bg-danger">ناموفق</span>; break;
                                default: <span class="badge bg-secondary">@row.Status</span>; break;
                            }
                        </td>
                        <td dir="ltr" class="small">@(row.Reference ?? "—")</td>
                        <td class="small">@(row.Description ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
