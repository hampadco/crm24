@model AdminChangePasswordViewModel
@{
    ViewData["Title"] = "تغییر رمز عبور";
}

<div class="admin-topbar">
    <h1 class="admin-page-title">@ViewData["Title"]</h1>
</div>

@if (TempData["AdminSuccess"] is string successMessage)
{
    <div class="admin-alert admin-alert-success">@successMessage</div>
}

<div class="admin-card">
    <div class="admin-card-header">
        <h2><i class="fas fa-key ms-1"></i> امنیت حساب مدیر</h2>
    </div>
    <div class="admin-card-body">
        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="All" class="admin-alert admin-alert-danger"></div>

            <div class="admin-form-grid">
                <div class="admin-form-group col-12 col-md-6">
                    <label asp-for="CurrentPassword" class="admin-form-label"></label>
                    <input asp-for="CurrentPassword" class="form-control admin-form-control" autocomplete="current-password" />
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>
                <div class="admin-form-group col-12 col-md-6">
                    <label asp-for="NewPassword" class="admin-form-label"></label>
                    <input asp-for="NewPassword" class="form-control admin-form-control" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div class="admin-form-group col-12 col-md-6">
                    <label asp-for="ConfirmPassword" class="admin-form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control admin-form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="admin-form-actions mt-3">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save ms-1"></i> ذخیره رمز جدید</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
