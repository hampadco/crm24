@model AdminLoginViewModel
@{
    Layout = "/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "ورود به پنل مدیریت";
}

<div class="card">
    <div class="card-body">
        <div class="app-brand justify-content-center mb-4">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="app-brand-link gap-2">
                <span class="app-brand-logo demo"><i class="bx bxs-shield-alt-2 fs-2 text-primary"></i></span>
                <span class="app-brand-text demo text-body fw-bold fs-4">BamaCRM</span>
            </a>
        </div>

        <h4 class="mb-1 text-center">پنل مدیریت اصلی</h4>
        <p class="mb-4 text-center text-muted">مدیریت مشتریان، اشتراک‌ها و محتوای سایت</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

        <form asp-action="Login" method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="mb-3">
                <label asp-for="Username" class="form-label">نام کاربری</label>
                <input asp-for="Username" class="form-control" dir="ltr" autofocus autocomplete="username" />
            </div>
            <div class="mb-4">
                <label asp-for="Password" class="form-label">رمز عبور</label>
                <input asp-for="Password" type="password" class="form-control" dir="ltr" autocomplete="current-password" />
            </div>
            <button type="submit" class="btn btn-primary d-grid w-100">ورود</button>
        </form>
    </div>
</div>
