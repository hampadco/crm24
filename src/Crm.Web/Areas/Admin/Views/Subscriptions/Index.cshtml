@using Crm.Core.Entities
@using Crm.Web.Models.Admin
@using Crm.Web.Services
@model PagedList<Subscription>
@{
    ViewData["Title"] = "اشتراک‌ها";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h4 class="mb-0">
        <i class="bx bx-id-card text-primary me-1"></i>
        @ViewData["Title"]
        <span class="badge bg-label-secondary rounded-pill align-middle">@Model.TotalCount.ToFa()</span>
    </h4>
</div>

<partial name="_AdminAlerts" />

<div class="card">
    @if (Model.TotalCount > 0)
    {
        <div class="card-header pb-0">
            <partial name="_AdminListMeta" model="Model" />
        </div>
    }
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>مشتری</th>
                    <th>پلن</th>
                    <th>شروع</th>
                    <th>پایان</th>
                    <th>مبلغ</th>
                    <th>پرداختی</th>
                    <th>نوع</th>
                    <th>وضعیت</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-5">اشتراکی ثبت نشده است.</td></tr>
                }
                @foreach (var sub in Model.Items)
                {
                    <tr>
                        <td><a asp-controller="Tenants" asp-action="Details" asp-route-id="@sub.TenantId">@sub.Tenant.Name</a></td>
                        <td>@sub.Plan.Name</td>
                        <td>@PersianDateHelper.ToJalaliDate(sub.StartsAtUtc)</td>
                        <td>@PersianDateHelper.ToJalaliDate(sub.EndsAtUtc)</td>
                        <td>@sub.Amount.ToString("N0")</td>
                        <td>@sub.Payments.Sum(p => p.Amount).ToString("N0")</td>
                        <td>
                            @if (PlatformAdminService.IsGiftSubscription(sub))
                            {
                                <span class="badge bg-info">هدیه</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">عادی</span>
                            }
                        </td>
                        <td>
                            @switch (sub.Status)
                            {
                                case SubscriptionStatus.Active: <span class="badge bg-success">فعال</span>; break;
                                case SubscriptionStatus.Expired: <span class="badge bg-secondary">منقضی</span>; break;
                                case SubscriptionStatus.Canceled: <span class="badge bg-danger">لغو</span>; break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            <partial name="_AdminPagination" model="Model" />
        </div>
    }
</div>
