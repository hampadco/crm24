@using Crm.Core.Entities
@using Crm.Web.Services
@model List<Subscription>
@{
    ViewData["Title"] = "اشتراک‌ها";
}

<div class="admin-topbar">
    <h1 class="admin-page-title">@ViewData["Title"]</h1>
</div>

<partial name="_AdminAlerts" />

<div class="admin-card">
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>مشتری</th>
                    <th>پلن</th>
                    <th>شروع</th>
                    <th>پایان</th>
                    <th>مبلغ</th>
                    <th>پرداختی</th>
                    <th>نوع</th>
                    <th>وضعیت</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">اشتراکی ثبت نشده است.</td></tr>
                }
                @foreach (var sub in Model)
                {
                    <tr>
                        <td><a asp-controller="Tenants" asp-action="Details" asp-route-id="@sub.TenantId">@sub.Tenant.Name</a></td>
                        <td>@sub.Plan.Name</td>
                        <td>@PersianDateHelper.ToJalaliDate(sub.StartsAtUtc)</td>
                        <td>@PersianDateHelper.ToJalaliDate(sub.EndsAtUtc)</td>
                        <td>@sub.Amount.ToString("N0")</td>
                        <td>@sub.Payments.Sum(p => p.Amount).ToString("N0")</td>
                        <td>
                            @if (PlatformAdminService.IsGiftSubscription(sub))
                            {
                                <span class="badge bg-info">هدیه</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">عادی</span>
                            }
                        </td>
                        <td>
                            @switch (sub.Status)
                            {
                                case SubscriptionStatus.Active: <span class="badge bg-success">فعال</span>; break;
                                case SubscriptionStatus.Expired: <span class="badge bg-secondary">منقضی</span>; break;
                                case SubscriptionStatus.Canceled: <span class="badge bg-danger">لغو</span>; break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
