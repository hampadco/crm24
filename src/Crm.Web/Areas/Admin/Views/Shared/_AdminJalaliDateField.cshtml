@using Crm.Web.Services
@model DateTime
@{
    var fieldName = ViewData["FieldName"] as string ?? "PublishedAt";
    var fieldId = ViewData["FieldId"] as string ?? fieldName;
    var label = ViewData["Label"] as string ?? "تاریخ انتشار";
    var isoValue = Model.ToString("yyyy-MM-dd'T'HH:mm");
}

<div class="admin-form-group">
    <label class="admin-form-label" for="@fieldId">@label</label>
    <input type="text" name="@fieldName" id="@fieldId" value="@isoValue"
           class="form-control jalali-datetime" autocomplete="off" dir="ltr" />
    <div class="admin-form-text">تقویم شمسی — تاریخ و ساعت انتشار</div>
</div>
