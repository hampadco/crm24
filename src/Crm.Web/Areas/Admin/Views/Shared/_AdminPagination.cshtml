@model dynamic
@{
    var page = (int)Model.Page;
    var totalPages = (int)Model.TotalPages;
    var search = Model.Search as string;
}

@if (totalPages > 1)
{
    <nav class="admin-pagination" aria-label="صفحه‌بندی">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(page - 1)" asp-route-search="@search">قبلی</a>
            </li>

            @{
                var start = Math.Max(1, page - 2);
                var end = Math.Min(totalPages, page + 2);
            }

            @if (start > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-search="@search">@(1.ToFa())</a>
                </li>
                @if (start > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }

            @for (var i = start; i <= end; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search">@i.ToFa()</a>
                </li>
            }

            @if (end < totalPages)
            {
                @if (end < totalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="@totalPages" asp-route-search="@search">@totalPages.ToFa()</a>
                </li>
            }

            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(page + 1)" asp-route-search="@search">بعدی</a>
            </li>
        </ul>
    </nav>
}
