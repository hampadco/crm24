@model dynamic
@{
    var page = (int)Model.Page;
    var totalPages = (int)Model.TotalPages;
    var search = Model.Search as string;
    var extraRoutes = ViewBag.PaginationRoutes as IDictionary<string, object?> ?? new Dictionary<string, object?>();

    Dictionary<string, string> PageRoute(int p)
    {
        var routes = new Dictionary<string, string> { ["page"] = p.ToString() };
        foreach (var kv in extraRoutes)
        {
            if (kv.Value is not null)
                routes[kv.Key] = kv.Value.ToString()!;
        }
        if (!string.IsNullOrWhiteSpace(search) && !routes.ContainsKey("q") && !routes.ContainsKey("search"))
            routes["search"] = search;
        return routes;
    }
}

@if (totalPages > 1)
{
    <nav aria-label="صفحه‌بندی">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-all-route-data="PageRoute(page - 1)">قبلی</a>
            </li>

            @{
                var start = Math.Max(1, page - 2);
                var end = Math.Min(totalPages, page + 2);
            }

            @if (start > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-all-route-data="PageRoute(1)">@(1.ToFa())</a>
                </li>
                @if (start > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }

            @for (var i = start; i <= end; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-all-route-data="PageRoute(i)">@i.ToFa()</a>
                </li>
            }

            @if (end < totalPages)
            {
                @if (end < totalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-all-route-data="PageRoute(totalPages)">@totalPages.ToFa()</a>
                </li>
            }

            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-all-route-data="PageRoute(page + 1)">بعدی</a>
            </li>
        </ul>
    </nav>
}
