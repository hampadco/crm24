@model DashboardViewModel
@{
    ViewData["Title"] = "داشبورد";
    ViewData["PanelTitle"] = "پنل مدیریت اصلی";
}

<div class="card bg-label-primary mb-4">
    <div class="card-body">
        <h4 class="mb-1">سلام، به پنل مدیریت BamaCRM خوش آمدید</h4>
        <p class="mb-0">امروز @Model.TodayJalali — مشتریان، اشتراک‌ها و محتوای سایت را از اینجا مدیریت کنید.</p>
    </div>
</div>

@if (Model.Platform is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-primary"><i class="bx bx-buildings"></i></span></div>
                    <span class="d-block text-muted small">مشتریان</span>
                    <h4 class="mb-1">@Model.Platform.TotalTenants.ToFa()</h4>
                    <a asp-area="Admin" asp-controller="Tenants" asp-action="Index" class="small">مشاهده <i class="bx bx-chevron-left"></i></a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-success"><i class="bx bx-check-circle"></i></span></div>
                    <span class="d-block text-muted small">فعال</span>
                    <h4 class="mb-1">@Model.Platform.ActiveTenants.ToFa()</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-warning"><i class="bx bx-hourglass"></i></span></div>
                    <span class="d-block text-muted small">آزمایشی</span>
                    <h4 class="mb-1">@Model.Platform.TrialTenants.ToFa()</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-info"><i class="bx bx-id-card"></i></span></div>
                    <span class="d-block text-muted small">اشتراک فعال</span>
                    <h4 class="mb-1">@Model.Platform.ActiveSubscriptions.ToFa()</h4>
                    <a asp-area="Admin" asp-controller="Subscriptions" asp-action="Index" class="small">مدیریت <i class="bx bx-chevron-left"></i></a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-success"><i class="bx bx-coin-stack"></i></span></div>
                    <span class="d-block text-muted small">درآمد کل</span>
                    <h4 class="mb-1">@Model.Platform.TotalRevenue.ToFa()</h4>
                    <a asp-area="Admin" asp-controller="Transactions" asp-action="Index" class="small">تراکنش‌ها <i class="bx bx-chevron-left"></i></a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-danger"><i class="bx bx-trending-up"></i></span></div>
                    <span class="d-block text-muted small">درآمد ۳۰ روز</span>
                    <h4 class="mb-1">@Model.Platform.RevenueLast30Days.ToFa()</h4>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-primary"><i class="bx bx-news"></i></span></div>
                <span class="d-block text-muted small">وبلاگ / مقالات</span>
                <h4 class="mb-1">@Model.ArticleCount.ToFa()</h4>
                <a asp-area="Admin" asp-controller="Articles" asp-action="Index" class="small">مدیریت مقالات <i class="bx bx-chevron-left"></i></a>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-warning"><i class="bx bx-help-circle"></i></span></div>
                <span class="d-block text-muted small">سؤالات متداول</span>
                <h4 class="mb-1">@Model.FaqCount.ToFa()</h4>
                <a asp-area="Admin" asp-controller="Faqs" asp-action="Index" class="small">مدیریت FAQ <i class="bx bx-chevron-left"></i></a>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-success"><i class="bx bx-file"></i></span></div>
                <span class="d-block text-muted small">صفحات سایت</span>
                <h4 class="mb-1">@Model.SitePageCount.ToFa()</h4>
                <a asp-area="Admin" asp-controller="SitePages" asp-action="EditAbout" class="small">مدیریت صفحات <i class="bx bx-chevron-left"></i></a>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="avatar mb-2"><span class="avatar-initial rounded bg-label-info"><i class="bx bx-envelope"></i></span></div>
                <span class="d-block text-muted small">مشترکین خبرنامه</span>
                <h4 class="mb-1">@Model.SubscriberCount.ToFa()</h4>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bx bx-time-five text-primary me-1"></i> فعالیت اخیر محتوا</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>نوع</th>
                            <th>عنوان</th>
                            <th>تاریخ</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @if (!Model.RecentItems.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">هنوز محتوایی ثبت نشده است.</td>
                            </tr>
                        }
                        @foreach (var item in Model.RecentItems)
                        {
                            <tr>
                                <td>
                                    <span class="admin-recent-type admin-recent-type--@item.Type">@item.TypeLabel</span>
                                </td>
                                <td>@item.Title</td>
                                <td>@item.DateLabel</td>
                                <td class="text-end">
                                    <a href="@item.EditUrl" class="btn btn-sm btn-outline-secondary">ویرایش</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bx bx-bolt-circle text-primary me-1"></i> دسترسی سریع</h5>
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-area="Admin" asp-controller="Tenants" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bx bx-buildings me-1"></i> مشتریان
                </a>
                <a asp-area="Admin" asp-controller="Subscriptions" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bx bx-id-card me-1"></i> اشتراک‌ها
                </a>
                <a asp-area="Admin" asp-controller="Transactions" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bx bx-money me-1"></i> تراکنش‌ها
                </a>
                <a asp-area="Admin" asp-controller="Articles" asp-action="Create" class="btn btn-outline-secondary">
                    <i class="bx bx-news me-1"></i> مقاله جدید
                </a>
            </div>
        </div>
    </div>
</div>
