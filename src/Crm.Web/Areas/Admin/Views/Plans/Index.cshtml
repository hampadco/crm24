@using Crm.Web.Models.Admin
@model PagedList<Crm.Core.Entities.Plan>
@{
    ViewData["Title"] = "پلن‌ها و تعرفه";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h4 class="mb-0">
        <i class="bx bx-purchase-tag text-primary me-1"></i>
        @ViewData["Title"]
        <span class="badge bg-label-secondary rounded-pill align-middle">@Model.TotalCount.ToFa()</span>
    </h4>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bx bx-plus me-1"></i> پلن جدید
        </a>
    </div>
</div>

<partial name="_AdminAlerts" />

<div class="card">
    @if (Model.TotalCount > 0)
    {
        <div class="card-header pb-0">
            <partial name="_AdminListMeta" model="Model" />
        </div>
    }
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>نام</th>
                    <th>ماهانه</th>
                    <th>سالانه</th>
                    <th>کاربر</th>
                    <th>رکورد</th>
                    <th>فضا</th>
                    <th>وضعیت</th>
                    <th class="text-end">عملیات</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-5">پلنی تعریف نشده است.</td></tr>
                }
                @foreach (var plan in Model.Items)
                {
                    <tr>
                        <td>
                            <span class="fw-semibold">@plan.Name</span>
                            @if (plan.IsFeatured)
                            {
                                <span class="badge bg-primary ms-1">پیشنهادی</span>
                            }
                        </td>
                        <td>@plan.PriceMonthly.ToString("N0")</td>
                        <td>@plan.PriceYearly.ToString("N0")</td>
                        <td>@plan.MaxUsers</td>
                        <td>@plan.MaxRecords.ToString("N0")</td>
                        <td>@(plan.MaxStorageMb >= 1024 ? $"{plan.MaxStorageMb / 1024} GB" : $"{plan.MaxStorageMb} MB")</td>
                        <td>
                            @if (plan.IsActive)
                            {
                                <span class="badge bg-success">فعال</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">غیرفعال</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@plan.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            <partial name="_AdminPagination" model="Model" />
        </div>
    }
</div>
