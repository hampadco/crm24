@model List<Crm.Core.Entities.Plan>
@{
    ViewData["Title"] = "پلن‌ها و تعرفه";
}

<div class="admin-topbar">
    <h1 class="admin-page-title">@ViewData["Title"]</h1>
    <div class="admin-topbar-actions">
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus ms-1"></i> پلن جدید</a>
    </div>
</div>

<partial name="_AdminAlerts" />

<div class="admin-card">
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>نام</th>
                    <th>ماهانه</th>
                    <th>سالانه</th>
                    <th>کاربر</th>
                    <th>رکورد</th>
                    <th>فضا</th>
                    <th>وضعیت</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">پلنی تعریف نشده است.</td></tr>
                }
                @foreach (var plan in Model)
                {
                    <tr>
                        <td>
                            <span class="fw-semibold">@plan.Name</span>
                            @if (plan.IsFeatured)
                            {
                                <span class="badge bg-primary ms-1">پیشنهادی</span>
                            }
                        </td>
                        <td>@plan.PriceMonthly.ToString("N0")</td>
                        <td>@plan.PriceYearly.ToString("N0")</td>
                        <td>@plan.MaxUsers</td>
                        <td>@plan.MaxRecords.ToString("N0")</td>
                        <td>@(plan.MaxStorageMb >= 1024 ? $"{plan.MaxStorageMb / 1024} GB" : $"{plan.MaxStorageMb} MB")</td>
                        <td>
                            @if (plan.IsActive)
                            {
                                <span class="badge bg-success">فعال</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">غیرفعال</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@plan.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
