@model ContentCategory
@{
    ViewData["Title"] = "دسته جدید";
}

<div class="admin-topbar">
    <h1 class="admin-page-title">@ViewData["Title"]</h1>
    <div class="admin-topbar-actions">
        <a asp-action="Index" asp-route-type="@Model.Type" class="btn btn-outline-secondary btn-sm">بازگشت</a>
    </div>
</div>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="admin-alert admin-alert-danger"></div>
    <div class="admin-card">
        <div class="admin-card-body">
            <div class="admin-form-grid">
                <div class="admin-form-group col-6">
                    <label asp-for="Name" class="admin-form-label">نام</label>
                    <input asp-for="Name" class="form-control admin-form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="admin-form-group col-6">
                    <label asp-for="Slug" class="admin-form-label">Slug</label>
                    <input asp-for="Slug" class="form-control admin-form-control admin-slug-input" />
                </div>
                <div class="admin-form-group col-6">
                    <label asp-for="Type" class="admin-form-label">نوع محتوا</label>
                    <select asp-for="Type" class="form-select admin-form-control"
                            asp-items="Html.GetEnumSelectList<ContentCategoryType>()"></select>
                </div>
                <div class="admin-form-group col-6">
                    <label asp-for="SortOrder" class="admin-form-label">ترتیب</label>
                    <input asp-for="SortOrder" class="form-control admin-form-control" type="number" />
                </div>
            </div>
            <div class="admin-form-actions mt-3">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save ms-1"></i> ذخیره</button>
            </div>
        </div>
    </div>
</form>
