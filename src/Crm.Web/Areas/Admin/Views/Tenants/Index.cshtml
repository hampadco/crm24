@using Crm.Core.Entities
@using Crm.Web.Models.Admin
@model List<TenantListItem>
@{
    ViewData["Title"] = "مشتریان";
    var status = ViewData["Status"] as TenantStatus?;
}

<div class="admin-topbar">
    <h1 class="admin-page-title">@ViewData["Title"]</h1>
</div>

<partial name="_AdminAlerts" />

<div class="admin-card">
    <div class="admin-card-header">
        <form method="get" class="row g-2 align-items-center w-100">
            <div class="col-md-5">
                <input type="text" name="q" value="@ViewData["Search"]" class="form-control form-control-sm" placeholder="جستجوی نام یا شناسه..." />
            </div>
            <div class="col-md-4">
                <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">همه وضعیت‌ها</option>
                    <option value="Trial" selected="@(status == TenantStatus.Trial)">آزمایشی</option>
                    <option value="Active" selected="@(status == TenantStatus.Active)">فعال</option>
                    <option value="Suspended" selected="@(status == TenantStatus.Suspended)">معلق</option>
                    <option value="Expired" selected="@(status == TenantStatus.Expired)">منقضی</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-sm btn-primary w-100"><i class="fas fa-search ms-1"></i> جستجو</button>
            </div>
        </form>
    </div>
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>نام</th>
                    <th>شناسه</th>
                    <th>وضعیت</th>
                    <th>کاربر</th>
                    <th>رکورد</th>
                    <th>تاریخ ثبت</th>
                    <th>پایان تریال</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">موردی یافت نشد.</td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted">@item.Tenant.Id</td>
                        <td><a asp-action="Details" asp-route-id="@item.Tenant.Id" class="fw-semibold">@item.Tenant.Name</a></td>
                        <td dir="ltr"><code>@item.Tenant.Slug</code></td>
                        <td><partial name="_TenantStatusBadge" model="item.Tenant.Status" /></td>
                        <td>@item.UserCount.ToFa()</td>
                        <td>@item.RecordCount.ToFa()</td>
                        <td>@PersianDateHelper.ToJalaliDate(item.Tenant.CreatedAtUtc)</td>
                        <td>@(item.Tenant.TrialEndsAtUtc is DateTime t ? PersianDateHelper.ToJalaliDate(t) : "—")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Tenant.Id" class="btn btn-sm btn-outline-secondary">جزئیات</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
