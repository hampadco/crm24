@using Crm.Core.Entities
@using Crm.Web.Services
@model List<Ticket>
@{
    ViewData["PanelTitle"] = "پورتال مشتری";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bx bx-support text-primary me-1"></i> تیکت‌های من</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bx bx-plus me-1"></i> تیکت جدید</a>
</div>

<partial name="_Alerts" />

<div class="card">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead><tr><th>#</th><th>موضوع</th><th>وضعیت</th><th>تاریخ ثبت</th></tr></thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted py-5">هنوز تیکتی ثبت نکرده‌اید.</td></tr>
                }
                @foreach (var ticket in Model)
                {
                    <tr>
                        <td><a href="/Portal/tickets/@ticket.Id"><strong>@ticket.Number</strong></a></td>
                        <td>@ticket.Subject</td>
                        <td><partial name="_TicketBadges" model="ticket" /></td>
                        <td class="text-muted">@PersianDateHelper.ToJalaliDate(ticket.CreatedAtUtc)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
