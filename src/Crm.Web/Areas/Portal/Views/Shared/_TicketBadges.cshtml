@using Crm.Core.Entities
@model Ticket
@{
    var statusLabel = Model.Status switch
    {
        TicketStatus.Open => "باز",
        TicketStatus.InProgress => "در حال بررسی",
        TicketStatus.WaitingCustomer => "منتظر پاسخ شما",
        TicketStatus.Resolved => "حل‌شده",
        _ => "بسته"
    };
    var statusCls = Model.Status switch
    {
        TicketStatus.Open => "bg-label-primary",
        TicketStatus.InProgress => "bg-label-info",
        TicketStatus.WaitingCustomer => "bg-label-warning",
        TicketStatus.Resolved => "bg-label-success",
        _ => "bg-label-secondary"
    };
}
<span class="badge @statusCls">@statusLabel</span>
