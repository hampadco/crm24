@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "ورود به پورتال مشتریان";
}

<div class="card">
    <div class="card-body">
        <div class="app-brand justify-content-center mb-4">
            <span class="app-brand-logo demo"><i class="bx bxs-user-circle fs-2 text-primary"></i></span>
            <span class="app-brand-text demo text-body fw-bold fs-4 ms-2">پورتال مشتریان</span>
        </div>

        <h4 class="mb-1 text-center">خوش آمدید</h4>
        <p class="mb-4 text-center text-muted">برای پیگیری تیکت‌ها و فاکتورهای خود وارد شوید.</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">ایمیل</label>
                <input type="email" name="email" class="form-control" dir="ltr" autofocus required />
            </div>
            <div class="mb-3">
                <label class="form-label">رمز عبور</label>
                <input type="password" name="password" class="form-control" dir="ltr" required />
            </div>
            <button type="submit" class="btn btn-primary d-grid w-100">ورود</button>
        </form>

        <p class="text-center mt-3 mb-0 text-muted small">
            حساب پورتال توسط شرکت خدمات‌دهنده شما ساخته می‌شود.
        </p>
    </div>
</div>
