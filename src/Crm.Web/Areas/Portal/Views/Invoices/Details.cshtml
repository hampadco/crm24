@using Crm.Core.Entities
@using Crm.Web.Services
@model SalesDocument
@{
    ViewData["PanelTitle"] = "پورتال مشتری";
    var paid = Model.Payments.Sum(p => p.Amount);
    var remaining = Model.GrandTotal - paid;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bx bx-receipt text-primary me-1"></i> فاکتور شماره @Model.Number</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bx bx-right-arrow-alt me-1"></i> بازگشت</a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <p class="text-muted mb-3">تاریخ صدور: @PersianDateHelper.ToJalaliDate(Model.IssueDateUtc)</p>
                <div class="table-responsive">
                    <table class="table">
                        <thead><tr><th>#</th><th>شرح</th><th>تعداد</th><th>قیمت واحد</th><th>جمع</th></tr></thead>
                        <tbody>
                            @foreach (var line in Model.Lines.OrderBy(l => l.SortOrder))
                            {
                                <tr>
                                    <td>@line.SortOrder</td>
                                    <td>@line.Title</td>
                                    <td>@line.Quantity.ToString("0.##")</td>
                                    <td>@line.UnitPrice.ToString("N0")</td>
                                    <td>@line.LineTotal.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-active">
                                <td colspan="4" class="text-end"><strong>مبلغ نهایی</strong></td>
                                <td><strong>@Model.GrandTotal.ToString("N0") تومان</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">وضعیت پرداخت</h5></div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">پرداخت‌شده</span><strong>@paid.ToString("N0")</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">مانده</span>
                    <strong class="@(remaining > 0 ? "text-danger" : "text-success")">@remaining.ToString("N0")</strong>
                </div>

                @if (Context.Request.Query["payment"] == "success")
                {
                    <div class="alert alert-success mt-3 mb-0">پرداخت شما با موفقیت ثبت شد.</div>
                }
                else if (Context.Request.Query["payment"] == "failed")
                {
                    <div class="alert alert-danger mt-3 mb-0">پرداخت ناموفق بود.</div>
                }

                @if (remaining > 0)
                {
                    <form action="/Portal/invoices/@Model.Id/pay-online" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bx bx-credit-card me-1"></i> پرداخت آنلاین مانده
                        </button>
                    </form>
                }
            </div>
        </div>

        @if (Model.Installments.Count > 0)
        {
            <div class="card">
                <div class="card-header"><h5 class="mb-0">اقساط</h5></div>
                <ul class="list-group list-group-flush">
                    @foreach (var installment in Model.Installments.OrderBy(i => i.DueDateUtc))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@PersianDateHelper.ToJalaliDate(installment.DueDateUtc) — @installment.Amount.ToString("N0")</span>
                            <span class="badge @(installment.IsPaid ? "bg-label-success" : "bg-label-warning")">
                                @(installment.IsPaid ? "پرداخت شد" : "در انتظار")
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>
