@using Crm.Core.Entities
@using Crm.Web.Services
@{
    var tenant = (Tenant)ViewBag.Tenant;
    var current = (Subscription?)ViewBag.Current;
    var plans = (List<Crm.Core.Entities.Plan>)ViewBag.Plans;
}

<h4 class="mb-4"><i class="bx bx-badge-check text-primary me-1"></i> اشتراک و تمدید</h4>

<partial name="_Alerts" />

@if (Context.Request.Query["payment"] == "success")
{
    <div class="alert alert-success">پرداخت با موفقیت انجام و اشتراک تمدید شد.</div>
}
else if (Context.Request.Query["payment"] == "failed")
{
    <div class="alert alert-danger">پرداخت ناموفق بود.</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">وضعیت فعلی</h5></div>
            <div class="card-body">
                <p class="d-flex justify-content-between">
                    <span class="text-muted">وضعیت</span>
                    <span class="badge @(tenant.Status == TenantStatus.Active ? "bg-label-success" : tenant.Status == TenantStatus.Trial ? "bg-label-info" : "bg-label-danger")">
                        @(tenant.Status switch { TenantStatus.Active => "فعال", TenantStatus.Trial => "دوره آزمایشی", TenantStatus.Suspended => "معلق", _ => "منقضی" })
                    </span>
                </p>
                @if (current is not null)
                {
                    <p class="d-flex justify-content-between"><span class="text-muted">پلن</span><strong>@current.Plan.Name</strong></p>
                    <p class="d-flex justify-content-between mb-0"><span class="text-muted">پایان اشتراک</span><strong>@PersianDateHelper.ToJalaliDate(current.EndsAtUtc)</strong></p>
                }
                else if (tenant.TrialEndsAtUtc is DateTime trialEnd)
                {
                    <p class="d-flex justify-content-between mb-0"><span class="text-muted">پایان دوره آزمایشی</span><strong>@PersianDateHelper.ToJalaliDate(trialEnd)</strong></p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="row g-3">
            @foreach (var plan in plans)
            {
                var yearly = plan.PriceYearly > 0 ? plan.PriceYearly : plan.PriceMonthly * 12;
                <div class="col-md-4">
                    <div class="card h-100 @(plan.IsFeatured ? "border border-primary" : "")">
                        <div class="card-body text-center d-flex flex-column">
                            <h5>@plan.Name</h5>
                            <h4 class="my-2">@yearly.ToString("N0") <small class="fs-6 text-muted">تومان/سال</small></h4>
                            <p class="text-muted small flex-grow-1">تا @plan.MaxUsers کاربر — @plan.MaxRecords.ToString("N0") رکورد</p>
                            <form asp-action="Renew" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="planId" value="@plan.Id" />
                                <button type="submit" class="btn @(plan.IsFeatured ? "btn-primary" : "btn-outline-primary") w-100">
                                    <i class="bx bx-credit-card me-1"></i> تمدید آنلاین
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
