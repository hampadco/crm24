@using Crm.Core.Entities
@using Crm.Web.Services
@model List<ServiceContract>
@{
    ViewData["PanelTitle"] = "پشتیبانی";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bx bx-file-blank text-primary me-1"></i> قراردادهای خدمات</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bx bx-plus me-1"></i> قرارداد جدید</a>
</div>

<partial name="_Alerts" />

<div class="card">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr><th>نام</th><th>مشتری</th><th>بازه</th><th>تیکت</th><th>وضعیت</th><th class="text-end">عملیات</th></tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-5">قراردادی ثبت نشده است.</td></tr>
                }
                @foreach (var contract in Model)
                {
                    var expired = contract.EndUtc < DateTime.UtcNow;
                    <tr>
                        <td><strong>@contract.Name</strong></td>
                        <td>@contract.CustomerName</td>
                        <td>@PersianDateHelper.ToJalaliDate(contract.StartUtc) تا @PersianDateHelper.ToJalaliDate(contract.EndUtc)</td>
                        <td>@contract.TicketsUsed@(contract.MaxTickets > 0 ? $" از {contract.MaxTickets}" : " (نامحدود)")</td>
                        <td>
                            <span class="badge @(contract.IsActive && !expired ? "bg-label-success" : "bg-label-danger")">
                                @(expired ? "منقضی" : contract.IsActive ? "فعال" : "غیرفعال")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@contract.Id" class="btn btn-sm btn-icon btn-text-secondary">
                                <i class="bx bx-edit"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
