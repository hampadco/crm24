@model Crm.Web.Areas.App.Controllers.KanbanViewModel
@{
    ViewData["PanelTitle"] = Model.Module.PluralLabel;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h4 class="mb-0">
        <i class="bx bx-columns text-primary me-1"></i>
        کاریز @Model.Module.PluralLabel
    </h4>
    <div class="d-flex gap-2">
        <a href="/App/m/@Model.Module.Name" class="btn btn-outline-secondary">
            <i class="bx bx-list-ul me-1"></i> نمای لیست
        </a>
        <a href="/App/m/@Model.Module.Name/create" class="btn btn-primary">
            <i class="bx bx-plus me-1"></i> @Model.Module.SingularLabel جدید
        </a>
    </div>
</div>

<partial name="_Alerts" />

<form id="afToken">@Html.AntiForgeryToken()</form>

<div class="d-flex gap-3 overflow-auto pb-3 kanban-board" style="min-height: 60vh">
    @foreach (var (stage, cards) in Model.Columns)
    {
        <div class="flex-shrink-0 kanban-col">
            <div class="card h-100">
                <div class="card-header py-2 d-flex justify-content-between align-items-center"
                     style="border-top: 3px solid @(stage.Color ?? "#696cff")">
                    <span class="fw-semibold">@stage.Label</span>
                    <span class="badge bg-label-secondary rounded-pill kanban-count">@cards.Count</span>
                </div>
                <div class="card-body p-2 kanban-column" data-stage="@stage.Value" style="min-height: 200px">
                    @foreach (var card in cards)
                    {
                        <div class="card mb-2 kanban-card shadow-none border" data-id="@card.Id" style="cursor: grab">
                            <div class="card-body p-3">
                                <a href="/App/m/@Model.Module.Name/@card.Id/edit" class="fw-semibold d-block mb-1">@card.Title</a>
                                @if (card.Amount is not null)
                                {
                                    <div class="text-success small">@card.Amount</div>
                                }
                                @if (card.Subtitle is not null)
                                {
                                    <div class="text-muted small" dir="ltr">@card.Subtitle</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/panel-assets/vendor/libs/sortablejs/sortable.js"></script>
    <script>
        const canEdit = @(Model.CanEdit ? "true" : "false");
        const token = document.querySelector('#afToken input[name="__RequestVerificationToken"]').value;

        document.querySelectorAll('.kanban-column').forEach(col => {
            new Sortable(col, {
                group: 'kanban',
                animation: 150,
                disabled: !canEdit,
                onEnd: async (evt) => {
                    const recordId = evt.item.dataset.id;
                    const stage = evt.to.dataset.stage;
                    if (evt.from === evt.to) return;

                    const body = new URLSearchParams({ recordId, stage, __RequestVerificationToken: token });
                    const resp = await fetch('/App/kanban/@Model.Module.Name/move', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body
                    });
                    if (!resp.ok) {
                        evt.from.appendChild(evt.item); // برگشت در صورت خطا
                        return;
                    }
                    document.querySelectorAll('.kanban-column').forEach(c => {
                        c.closest('.card').querySelector('.kanban-count').textContent = c.querySelectorAll('.kanban-card').length;
                    });
                }
            });
        });
    </script>
}
