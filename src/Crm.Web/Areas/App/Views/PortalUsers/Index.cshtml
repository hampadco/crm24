@using Crm.Core.Entities
@model List<PortalUser>
@{
    ViewData["PanelTitle"] = "پشتیبانی";
    Dictionary<int, string> contacts = ViewBag.Contacts;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bx bx-user-circle text-primary me-1"></i> کاربران پورتال مشتریان</h4>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#portalUserModal">
        <i class="bx bx-plus me-1"></i> کاربر جدید
    </button>
</div>

<partial name="_Alerts" />

<div class="alert alert-info small mb-3">
    مشتریان از <a href="/Portal/Account/Login" target="_blank"><strong>/Portal/Account/Login</strong></a> وارد می‌شوند — نه از /App/Account/Login.
</div>

<div class="card">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead><tr><th>نام</th><th>ایمیل</th><th>مخاطب مرتبط</th><th>وضعیت</th><th class="text-end">عملیات</th></tr></thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-5">کاربر پورتالی ساخته نشده است.</td></tr>
                }
                @foreach (var user in Model)
                {
                    <tr>
                        <td><strong>@user.FullName</strong></td>
                        <td dir="ltr">@user.Email</td>
                        <td>@(user.ContactRecordId is int cid && contacts.TryGetValue(cid, out var title) ? title : "—")</td>
                        <td>
                            <span class="badge @(user.IsActive ? "bg-label-success" : "bg-label-secondary")">
                                @(user.IsActive ? "فعال" : "غیرفعال")
                            </span>
                        </td>
                        <td class="text-end">
                            <a href="/App/portal-users/@user.Id/edit" class="btn btn-sm btn-outline-primary">ویرایش</a>
                            <form action="/App/portal-users/@user.Id/toggle" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-icon btn-text-warning" title="فعال/غیرفعال">
                                    <i class="bx bx-power-off"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="portalUserModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/App/portal-users/create" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title">کاربر پورتال جدید</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">نام و نام خانوادگی</label>
                    <input type="text" name="fullName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">ایمیل</label>
                    <input type="email" name="email" class="form-control" dir="ltr" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">رمز عبور</label>
                    <input type="password" name="password" class="form-control" dir="ltr" minlength="6" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">مخاطب مرتبط (برای نمایش فاکتورها)</label>
                    <select name="contactRecordId" class="form-select">
                        <option value="">— انتخاب کنید —</option>
                        @foreach (var (id, title) in contacts)
                        {
                            <option value="@id">@title</option>
                        }
                    </select>
                    <div class="form-text">مخاطب را از <a href="/App/m/contacts">مخاطبین CRM</a> بسازید.</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">انصراف</button>
                <button type="submit" class="btn btn-primary">ساخت کاربر</button>
            </div>
        </form>
    </div>
</div>
