@using Crm.Core.Entities
@using Crm.Web.Areas.App.Controllers
@using Crm.Web.Services
@model List<LeaveRequest>
@{
    ViewData["PanelTitle"] = "منابع انسانی";
    Dictionary<int, string> users = ViewBag.Users;
    bool isAdmin = ViewBag.IsAdmin;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bx bx-calendar-minus text-primary me-1"></i> مرخصی و مأموریت</h4>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#leaveModal">
        <i class="bx bx-plus me-1"></i> درخواست جدید
    </button>
</div>

<partial name="_Alerts" />

<div class="card">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    @if (isAdmin)
                    {
                        <th>پرسنل</th>
                    }
                    <th>نوع</th><th>از</th><th>تا</th><th>دلیل</th><th>وضعیت</th>
                    @if (isAdmin)
                    {
                        <th class="text-end">بررسی</th>
                    }
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-5">درخواستی ثبت نشده است.</td></tr>
                }
                @foreach (var request in Model)
                {
                    <tr>
                        @if (isAdmin)
                        {
                            <td>@users.GetValueOrDefault(request.UserId, "—")</td>
                        }
                        <td>@LeavesController.TypeLabel(request.Type)</td>
                        <td>@PersianDateHelper.ToJalaliDate(request.FromUtc)</td>
                        <td>@PersianDateHelper.ToJalaliDate(request.ToUtc)</td>
                        <td>@(request.Reason ?? "—")</td>
                        <td>
                            <span class="badge @(request.Status switch { LeaveStatus.Approved => "bg-label-success", LeaveStatus.Rejected => "bg-label-danger", _ => "bg-label-warning" })">
                                @LeavesController.StatusLabel(request.Status)
                            </span>
                        </td>
                        @if (isAdmin)
                        {
                            <td class="text-end">
                                @if (request.Status == LeaveStatus.Pending)
                                {
                                    <form action="/App/leaves/@request.Id/review" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="approve" value="true" />
                                        <button type="submit" class="btn btn-sm btn-icon btn-text-success" title="تأیید">
                                            <i class="bx bx-check"></i>
                                        </button>
                                    </form>
                                    <form action="/App/leaves/@request.Id/review" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="approve" value="false" />
                                        <button type="submit" class="btn btn-sm btn-icon btn-text-danger" title="رد">
                                            <i class="bx bx-x"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="leaveModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/App/leaves/create" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title">درخواست مرخصی/مأموریت</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">نوع</label>
                    <select name="type" class="form-select">
                        <option value="Leave">مرخصی</option>
                        <option value="Mission">مأموریت</option>
                    </select>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label">از تاریخ</label>
                        <input type="date" name="fromUtc" class="form-control" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label">تا تاریخ</label>
                        <input type="date" name="toUtc" class="form-control" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">دلیل</label>
                    <textarea name="reason" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">انصراف</button>
                <button type="submit" class="btn btn-primary">ثبت درخواست</button>
            </div>
        </form>
    </div>
</div>
