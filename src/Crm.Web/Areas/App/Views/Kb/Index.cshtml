@using Crm.Core.Entities
@model List<KbArticle>
@{
    ViewData["PanelTitle"] = "پشتیبانی";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bx bx-book-open text-primary me-1"></i> پایگاه دانش</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bx bx-plus me-1"></i> مقاله جدید</a>
</div>

<partial name="_Alerts" />

<div class="card">
    <div class="card-header pb-0">
        <form method="get" class="row g-2">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="جستجو در مقالات..." />
                    <button class="btn btn-outline-primary" type="submit"><i class="bx bx-search"></i></button>
                </div>
            </div>
        </form>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead><tr><th>عنوان</th><th>دسته</th><th>پورتال</th><th class="text-end">عملیات</th></tr></thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted py-5">مقاله‌ای ثبت نشده است.</td></tr>
                }
                @foreach (var article in Model)
                {
                    <tr>
                        <td><strong>@article.Title</strong></td>
                        <td>@(article.Category ?? "—")</td>
                        <td>
                            <span class="badge @(article.IsPublishedToPortal ? "bg-label-success" : "bg-label-secondary")">
                                @(article.IsPublishedToPortal ? "منتشر در پورتال" : "داخلی")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@article.Id" class="btn btn-sm btn-icon btn-text-secondary">
                                <i class="bx bx-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@article.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('این مقاله حذف شود؟');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-icon btn-text-danger">
                                    <i class="bx bx-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
