@model Crm.Web.Areas.App.Models.RegisterViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "ثبت‌نام رایگان";
}

<div class="card">
    <div class="card-body">
        <div class="app-brand justify-content-center mb-4">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="app-brand-link gap-2">
                <span class="app-brand-logo demo"><i class="bx bxs-analyse fs-2 text-primary"></i></span>
                <span class="app-brand-text demo text-body fw-bold fs-4">BaMaCRM</span>
            </a>
        </div>

        <h4 class="mb-1 text-center">شروع دوره آزمایشی ۱۰ روزه 🚀</h4>
        <p class="mb-4 text-center text-muted">بدون نیاز به کارت بانکی — همین حالا CRM اختصاصی خود را بسازید.</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

        <form asp-action="Register" method="post">
            <div class="mb-3">
                <label asp-for="CompanyName" class="form-label"></label>
                <input asp-for="CompanyName" class="form-control" autofocus />
                <span asp-validation-for="CompanyName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" dir="ltr" autocomplete="username" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" dir="ltr" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary d-grid w-100">ساخت حساب و شروع</button>
        </form>

        <p class="text-center mt-3 mb-0">
            <span>قبلاً ثبت‌نام کرده‌اید؟</span>
            <a asp-action="Login">ورود</a>
        </p>
    </div>
</div>
