@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "پایان اشتراک";
}

<div class="card">
    <div class="card-body text-center">
        <div class="avatar avatar-xl mx-auto mb-3">
            <span class="avatar-initial rounded-circle bg-label-warning"><i class="bx bx-time-five fs-2"></i></span>
        </div>
        <h4 class="mb-2">دوره استفاده شما به پایان رسیده است</h4>
        <p class="text-muted mb-4">
            برای ادامه استفاده از CRM24 لازم است اشتراک خود را تمدید کنید.
            جهت تمدید با پشتیبانی تماس بگیرید یا از صفحه تعرفه‌ها پلن مناسب را انتخاب کنید.
        </p>
        <div class="d-flex justify-content-center gap-2">
            <a href="/pricing" class="btn btn-primary">مشاهده تعرفه‌ها</a>
            <a asp-area="" asp-controller="Pages" asp-action="Contact" class="btn btn-outline-secondary">تماس با پشتیبانی</a>
        </div>
    </div>
</div>
