@using Crm.Core.Entities
@model List<Vendor>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bx bx-store text-primary me-1"></i> تأمین‌کنندگان</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bx bx-plus me-1"></i> تأمین‌کننده جدید</a>
</div>

<partial name="_Alerts" />

<div class="card">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead><tr><th>نام</th><th>تلفن</th><th>ایمیل</th><th>وضعیت</th><th></th></tr></thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-5">تأمین‌کننده‌ای ثبت نشده است.</td></tr>
                }
                @foreach (var vendor in Model)
                {
                    <tr>
                        <td><strong>@vendor.Name</strong></td>
                        <td class="text-muted">@(vendor.Phone ?? "—")</td>
                        <td class="text-muted">@(vendor.Email ?? "—")</td>
                        <td><span class="badge @(vendor.IsActive ? "bg-label-success" : "bg-label-secondary")">@(vendor.IsActive ? "فعال" : "غیرفعال")</span></td>
                        <td><a asp-action="Edit" asp-route-id="@vendor.Id" class="btn btn-sm btn-outline-primary"><i class="bx bx-edit"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
