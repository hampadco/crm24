@using Crm.Core.Entities
@model Vendor

<h4 class="mb-4"><i class="bx bx-store text-primary me-1"></i> @ViewData["Title"]</h4>

<partial name="_Alerts" />

<div class="card" style="max-width:680px">
    <div class="card-body">
        <form asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">نام *</label>
                    <input type="text" name="name" value="@Model.Name" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">تلفن</label>
                    <input type="text" name="phone" value="@Model.Phone" class="form-control" dir="ltr" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">ایمیل</label>
                    <input type="email" name="email" value="@Model.Email" class="form-control" dir="ltr" />
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <label class="form-check">
                        <input type="checkbox" name="isActive" value="true" class="form-check-input" checked="@(Model.Id == 0 || Model.IsActive)" />
                        <span class="form-check-label">فعال</span>
                    </label>
                </div>
                <div class="col-12">
                    <label class="form-label">نشانی</label>
                    <input type="text" name="address" value="@Model.Address" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">یادداشت</label>
                    <textarea name="notes" class="form-control" rows="2">@Model.Notes</textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="bx bx-save me-1"></i> ذخیره</button>
                <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
            </div>
        </form>
    </div>
</div>
