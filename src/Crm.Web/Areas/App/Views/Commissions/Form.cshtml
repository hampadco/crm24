@model Crm.Web.Areas.App.Controllers.CommissionRuleFormModel
@{
    ViewData["PanelTitle"] = "مشارکت در فروش";
    List<Crm.Core.Entities.Product> products = ViewBag.Products;
}

<h4 class="mb-4"><i class="bx bx-gift text-primary me-1"></i> @ViewData["Title"]</h4>

<partial name="_Alerts" />

<div class="card">
    <div class="card-body">
        <form asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label" asp-for="Name"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label" asp-for="ProductId"></label>
                    <select asp-for="ProductId" class="form-select">
                        <option value="">کل فاکتور</option>
                        @foreach (var product in products)
                        {
                            <option value="@product.Id">@product.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label" asp-for="Percent"></label>
                    <input asp-for="Percent" class="form-control" type="number" step="any" min="0" max="100" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" asp-for="FixedAmount"></label>
                    <input asp-for="FixedAmount" class="form-control" type="number" step="any" min="0" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" asp-for="MinInvoiceAmount"></label>
                    <input asp-for="MinInvoiceAmount" class="form-control" type="number" step="any" min="0" />
                    <div class="form-text">پلکان فروش: قانون فقط برای فاکتورهای بزرگ‌تر از این مبلغ اجرا می‌شود.</div>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label class="form-check-label" asp-for="IsActive"></label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bx bx-save me-1"></i> ذخیره</button>
                <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
            </div>
        </form>
    </div>
</div>
