@using Crm.Web.Areas.App.Controllers
@model List<Crm.Core.Entities.CommissionRule>
@{
    ViewData["PanelTitle"] = "مشارکت در فروش";
    List<CommissionReportRow> report = ViewBag.Report;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h4 class="mb-0"><i class="bx bx-gift text-primary me-1"></i> مشارکت در فروش (پورسانت)</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bx bx-plus me-1"></i> قانون جدید</a>
</div>

<partial name="_Alerts" />

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">قوانین پورسانت</h5></div>
            <div class="table-responsive text-nowrap">
                <table class="table table-hover">
                    <thead>
                        <tr><th>نام</th><th>دامنه</th><th>درصد</th><th>مبلغ ثابت</th><th>حداقل فاکتور</th><th>وضعیت</th><th></th></tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @if (Model.Count == 0)
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">قانونی تعریف نشده است.</td></tr>
                        }
                        @foreach (var rule in Model)
                        {
                            <tr>
                                <td><strong>@rule.Name</strong></td>
                                <td>@(rule.Product?.Name ?? "کل فاکتور")</td>
                                <td>@(rule.Percent > 0 ? rule.Percent.ToString("0.#") + "%" : "—")</td>
                                <td>@(rule.FixedAmount > 0 ? rule.FixedAmount.ToString("N0") : "—")</td>
                                <td>@(rule.MinInvoiceAmount > 0 ? rule.MinInvoiceAmount.ToString("N0") : "—")</td>
                                <td>
                                    <span class="badge @(rule.IsActive ? "bg-label-success" : "bg-label-secondary")">
                                        @(rule.IsActive ? "فعال" : "غیرفعال")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@rule.Id" class="btn btn-sm btn-icon btn-text-secondary">
                                        <i class="bx bx-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><h5 class="mb-0">گزارش پورسانت کارشناسان</h5></div>
            <div class="table-responsive text-nowrap">
                <table class="table">
                    <thead>
                        <tr><th>کارشناس</th><th>تعداد معامله</th><th>جمع پورسانت</th></tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @if (report.Count == 0)
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">هنوز پورسانتی محاسبه نشده است.</td></tr>
                        }
                        @foreach (var row in report)
                        {
                            <tr>
                                <td>@row.UserName</td>
                                <td>@row.DealCount</td>
                                <td><strong>@row.Total.ToString("N0") تومان</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
