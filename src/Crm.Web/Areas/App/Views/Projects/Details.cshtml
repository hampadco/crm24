@using Crm.Core.Entities
@using Crm.Web.Services
@using Crm.Web.Areas.App.Controllers
@model Project
@{
    var users = (Dictionary<int, string>)ViewBag.Users;
    var progress = Model.Tasks.Count == 0 ? 0 : (int)Model.Tasks.Average(t => t.ProgressPercent);
    var ganttStart = Model.Tasks.Count > 0 ? Model.Tasks.Min(t => t.StartUtc) : Model.StartUtc;
    var ganttEnd = Model.Tasks.Count > 0 ? Model.Tasks.Max(t => t.EndUtc) : Model.EndUtc;
    var totalDays = Math.Max(1, (ganttEnd - ganttStart).TotalDays);
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h4 class="mb-0">
        <i class="bx bx-briefcase-alt-2 text-primary me-1"></i> @Model.Name
        <span class="badge @(Model.Status switch { ProjectStatus.Active => "bg-label-success", ProjectStatus.OnHold => "bg-label-warning", ProjectStatus.Completed => "bg-label-info", _ => "bg-label-secondary" })">
            @ProjectsController.StatusLabel(Model.Status)
        </span>
    </h4>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="bx bx-edit me-1"></i> ویرایش</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bx bx-right-arrow-alt me-1"></i> بازگشت</a>
    </div>
</div>

<partial name="_Alerts" />

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">مشخصات</h5></div>
            <div class="card-body">
                <p class="d-flex justify-content-between"><span class="text-muted">مشتری</span><strong>@(Model.CustomerName ?? "—")</strong></p>
                <p class="d-flex justify-content-between"><span class="text-muted">بودجه</span><strong>@Model.Budget.ToString("N0") تومان</strong></p>
                <p class="d-flex justify-content-between"><span class="text-muted">شروع</span><strong>@PersianDateHelper.ToJalaliDate(Model.StartUtc)</strong></p>
                <p class="d-flex justify-content-between"><span class="text-muted">پایان</span><strong>@PersianDateHelper.ToJalaliDate(Model.EndUtc)</strong></p>
                <p class="d-flex justify-content-between mb-2"><span class="text-muted">پیشرفت کل</span><strong>@progress%</strong></p>
                <div class="progress" style="height:10px"><div class="progress-bar" style="width:@(progress)%"></div></div>
                @if (Model.ShowInPortal)
                {
                    <p class="mt-3 mb-0"><span class="badge bg-label-info">قابل مشاهده در پورتال مشتری</span></p>
                }
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr /><p class="text-muted mb-0" style="white-space:pre-wrap">@Model.Description</p>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h5 class="mb-0">فازها</h5></div>
            <ul class="list-group list-group-flush">
                @foreach (var phase in Model.Phases)
                {
                    var phaseTasks = Model.Tasks.Where(t => t.PhaseId == phase.Id).ToList();
                    var phaseProgress = phaseTasks.Count == 0 ? 0 : (int)phaseTasks.Average(t => t.ProgressPercent);
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong>@phase.Name</strong>
                            <small class="text-muted">@phaseTasks.Count وظیفه — @phaseProgress%</small>
                        </div>
                        <div class="progress" style="height:6px"><div class="progress-bar bg-info" style="width:@(phaseProgress)%"></div></div>
                    </li>
                }
                <li class="list-group-item">
                    <form asp-action="AddPhase" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="text" name="name" class="form-control form-control-sm" placeholder="نام فاز جدید..." required />
                        <button type="submit" class="btn btn-sm btn-primary"><i class="bx bx-plus"></i></button>
                    </form>
                </li>
            </ul>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">وظایف</h5></div>
            <div class="table-responsive text-nowrap">
                <table class="table table-sm">
                    <thead><tr><th>وظیفه</th><th>فاز</th><th>مسئول</th><th>بازه</th><th style="min-width:140px">پیشرفت</th></tr></thead>
                    <tbody>
                        @foreach (var task in Model.Tasks)
                        {
                            <tr>
                                <td>@task.Name</td>
                                <td class="text-muted">@(Model.Phases.FirstOrDefault(f => f.Id == task.PhaseId)?.Name ?? "—")</td>
                                <td class="text-muted">@(task.AssignedUserId is int uid && users.TryGetValue(uid, out var u) ? u : "—")</td>
                                <td class="text-muted small">@PersianDateHelper.ToJalaliDate(task.StartUtc) تا @PersianDateHelper.ToJalaliDate(task.EndUtc)</td>
                                <td>
                                    <form asp-action="SetTaskProgress" asp-route-taskId="@task.Id" method="post" class="d-flex align-items-center gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="number" name="percent" value="@task.ProgressPercent" min="0" max="100" class="form-control form-control-sm" style="width:70px" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bx bx-check"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (Model.Tasks.Count == 0)
                        {
                            <tr><td colspan="5" class="text-center text-muted py-3">وظیفه‌ای ثبت نشده است.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-body border-top">
                <form asp-action="AddTask" asp-route-id="@Model.Id" method="post" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div class="col-md-3">
                        <label class="form-label small">وظیفه جدید</label>
                        <input type="text" name="name" class="form-control form-control-sm" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">فاز</label>
                        <select name="phaseId" class="form-select form-select-sm">
                            <option value="">—</option>
                            @foreach (var phase in Model.Phases)
                            {
                                <option value="@phase.Id">@phase.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">مسئول</label>
                        <select name="assignedUserId" class="form-select form-select-sm">
                            <option value="">—</option>
                            @foreach (var user in users)
                            {
                                <option value="@user.Key">@user.Value</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">شروع</label>
                        <input type="text" name="startUtc" value="@PersianDateHelper.ToIsoDate(DateTime.UtcNow)" class="form-control form-control-sm jalali-date" autocomplete="off" dir="ltr" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">پایان</label>
                        <input type="text" name="endUtc" value="@PersianDateHelper.ToIsoDate(DateTime.UtcNow.AddDays(7))" class="form-control form-control-sm jalali-date" autocomplete="off" dir="ltr" />
                    </div>
                    <div class="col-md-1">
                        <button type="submit" class="btn btn-sm btn-primary w-100"><i class="bx bx-plus"></i></button>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.Tasks.Count > 0)
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <h5 class="mb-0">نمای گانت</h5>
                    <small class="text-muted">@PersianDateHelper.ToJalaliDate(ganttStart) تا @PersianDateHelper.ToJalaliDate(ganttEnd)</small>
                </div>
                <div class="card-body">
                    @foreach (var task in Model.Tasks)
                    {
                        var offsetPct = Math.Max(0, (task.StartUtc - ganttStart).TotalDays / totalDays * 100);
                        var widthPct = Math.Max(2, (task.EndUtc - task.StartUtc).TotalDays / totalDays * 100);
                        var barClass = task.Status switch
                        {
                            ProjectTaskStatus.Done => "bg-success",
                            ProjectTaskStatus.InProgress => "bg-primary",
                            _ => "bg-secondary"
                        };
                        <div class="d-flex align-items-center mb-2">
                            <div class="text-truncate gantt-label" title="@task.Name">@task.Name</div>
                            <div class="flex-grow-1 position-relative bg-lighter rounded" style="height:22px">
                                <div class="position-absolute rounded @barClass d-flex align-items-center justify-content-center text-white small"
                                     style="right:@(offsetPct.ToString("0.#"))%; width:@(widthPct.ToString("0.#"))%; height:22px; opacity:.85">
                                    @task.ProgressPercent%
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
