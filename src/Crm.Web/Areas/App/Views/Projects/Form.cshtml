@using Crm.Core.Entities
@model Project

<h4 class="mb-4"><i class="bx bx-briefcase-alt-2 text-primary me-1"></i> @ViewData["Title"]</h4>

<partial name="_Alerts" />

<div class="card" style="max-width:760px">
    <div class="card-body">
        <form asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="contactRecordId" value="@Model.ContactRecordId" />

            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label">نام پروژه *</label>
                    <input type="text" name="name" value="@Model.Name" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">وضعیت</label>
                    <select name="status" class="form-select">
                        @foreach (ProjectStatus status in Enum.GetValues<ProjectStatus>())
                        {
                            <option value="@status" selected="@(Model.Status == status)">
                                @Crm.Web.Areas.App.Controllers.ProjectsController.StatusLabel(status)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">مشتری</label>
                    <input type="text" name="customerName" value="@Model.CustomerName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">بودجه (تومان)</label>
                    <input type="number" name="budget" value="@Model.Budget.ToString("0")" class="form-control" min="0" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">تاریخ شروع</label>
                    <input type="date" name="startUtc" value="@Model.StartUtc.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">تاریخ پایان</label>
                    <input type="date" name="endUtc" value="@Model.EndUtc.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">توضیحات</label>
                    <textarea name="description" class="form-control" rows="3">@Model.Description</textarea>
                </div>
                <div class="col-12">
                    <label class="form-check">
                        <input type="checkbox" name="showInPortal" value="true" class="form-check-input" checked="@Model.ShowInPortal" />
                        <span class="form-check-label">نمایش وضعیت پروژه در پورتال مشتری</span>
                    </label>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="bx bx-save me-1"></i> ذخیره</button>
                <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
            </div>
        </form>
    </div>
</div>
