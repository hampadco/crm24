@using Crm.Core.Entities
@model List<MessageTemplate>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bx bx-message-square-detail text-primary me-1"></i> قالب‌های پیام</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#templateModal" onclick="openTemplate(0, '', '', true)">
        <i class="bx bx-plus me-1"></i> قالب جدید
    </button>
</div>

<partial name="_Alerts" />

<div class="row g-4">
    @if (Model.Count == 0)
    {
        <div class="col-12 text-center text-muted py-5">قالبی ثبت نشده است.</div>
    }
    @foreach (var template in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="mb-0">@template.Title</h5>
                        <span class="badge @(template.IsPublic ? "bg-label-success" : "bg-label-secondary")">@(template.IsPublic ? "عمومی" : "خصوصی")</span>
                    </div>
                    <p class="text-muted mb-3" style="white-space:pre-wrap">@(template.Body.Length > 160 ? template.Body[..160] + "…" : template.Body)</p>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#templateModal"
                                onclick="openTemplate(@template.Id, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(template.Title)), @Html.Raw(System.Text.Json.JsonSerializer.Serialize(template.Body)), @(template.IsPublic ? "true" : "false"))">
                            <i class="bx bx-edit"></i>
                        </button>
                        <form asp-action="Delete" asp-route-id="@template.Id" method="post" onsubmit="return confirm('حذف شود؟')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bx bx-trash"></i></button>
                        </form>
                        <button class="btn btn-sm btn-outline-secondary" onclick="navigator.clipboard.writeText(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(template.Body)))" title="کپی متن">
                            <i class="bx bx-copy"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="templateModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Save" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="tplId" value="0" />
            <div class="modal-header">
                <h5 class="modal-title">قالب پیام</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">عنوان *</label>
                    <input type="text" name="title" id="tplTitle" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">متن *</label>
                    <textarea name="body" id="tplBody" class="form-control" rows="5" required></textarea>
                </div>
                <label class="form-check">
                    <input type="checkbox" name="isPublic" id="tplPublic" value="true" class="form-check-input" />
                    <span class="form-check-label">عمومی (قابل استفاده برای همه کاربران)</span>
                </label>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">ذخیره</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openTemplate(id, title, body, isPublic) {
        document.getElementById('tplId').value = id;
        document.getElementById('tplTitle').value = title;
        document.getElementById('tplBody').value = body;
        document.getElementById('tplPublic').checked = isPublic;
    }
</script>
}
