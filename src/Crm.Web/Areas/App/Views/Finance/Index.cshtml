@using Crm.Core.Entities
@using Crm.Web.Areas.App.Controllers
@model List<SalesDocument>
@{
    SalesDocumentKind kind = ViewBag.Kind;
    string kindSlug = ViewBag.KindSlug;
    var kindLabel = FinanceController.KindLabel(kind);
    ViewData["PanelTitle"] = "مالی";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h4 class="mb-0">
        <i class="bx bx-receipt text-primary me-1"></i>
        @(kindLabel)ها
        <span class="badge bg-label-secondary rounded-pill align-middle">@Model.Count</span>
    </h4>
    <a href="/App/finance/@kindSlug/create" class="btn btn-primary"><i class="bx bx-plus me-1"></i> @kindLabel جدید</a>
</div>

<partial name="_Alerts" />

<div class="card">
    <div class="card-header pb-0">
        <form method="get" class="row g-2">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="جستجو در نام مشتری..." />
                    <button class="btn btn-outline-primary" type="submit"><i class="bx bx-search"></i></button>
                </div>
            </div>
        </form>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>شماره</th>
                    <th>مشتری</th>
                    <th>تاریخ صدور</th>
                    <th>مبلغ کل</th>
                    <th>وضعیت</th>
                    <th class="text-end">عملیات</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-5">هنوز سندی ثبت نشده است.</td></tr>
                }
                @foreach (var doc in Model)
                {
                    <tr>
                        <td><a href="/App/finance/doc/@doc.Id"><strong>@doc.Number</strong></a></td>
                        <td>@doc.CustomerName</td>
                        <td>@Crm.Web.Services.PersianDateHelper.ToJalaliDate(doc.IssueDateUtc)</td>
                        <td>@doc.GrandTotal.ToString("N0") تومان</td>
                        <td><partial name="_DocStatusBadge" model="doc.Status" /></td>
                        <td class="text-end">
                            <a href="/App/finance/doc/@doc.Id" class="btn btn-sm btn-icon btn-text-secondary" title="جزئیات">
                                <i class="bx bx-show"></i>
                            </a>
                            <a href="/App/finance/doc/@doc.Id/print" target="_blank" class="btn btn-sm btn-icon btn-text-secondary" title="چاپ">
                                <i class="bx bx-printer"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
