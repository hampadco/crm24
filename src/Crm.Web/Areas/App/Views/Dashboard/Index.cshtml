@model Crm.Web.Areas.App.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "داشبورد";
    ViewData["PanelTitle"] = Model.Tenant.Name;
}

<partial name="_Alerts" />

<div class="row g-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h4 class="card-title mb-1">به «@Model.Tenant.Name» خوش آمدید 👋</h4>
                    <p class="text-muted mb-0">با دکمه «افزودن ویجت» داشبورد را شخصی‌سازی کنید.</p>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    @if (Model.TrialDaysLeft is int days)
                    {
                        <div class="badge bg-label-warning fs-6 p-2">
                            <i class="bx bx-time-five me-1"></i> @days روز از دوره آزمایشی باقی مانده
                        </div>
                    }
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#widgetModal">
                        <i class="bx bx-plus me-1"></i> افزودن ویجت
                    </button>
                </div>
            </div>
        </div>
    </div>

    @foreach (var widget in Model.Widgets)
    {
        <div class="@(widget.Widget.Type == "counter" ? "col-md-3 col-6" : "col-md-6")">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center pb-2">
                    <h6 class="mb-0">@widget.Widget.Title</h6>
                    <form action="/App/dashboard/widgets/@widget.Widget.Id/remove" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-xs btn-icon btn-text-secondary" title="حذف ویجت">
                            <i class="bx bx-x"></i>
                        </button>
                    </form>
                </div>
                <div class="card-body">
                    @if (widget.Widget.Type == "counter")
                    {
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar">
                                <span class="avatar-initial rounded bg-label-primary"><i class="bx @(widget.Module?.Icon ?? "bx-cube")"></i></span>
                            </div>
                            <h3 class="mb-0">@widget.CounterValue.ToString("N0")</h3>
                        </div>
                    }
                    else
                    {
                        <div class="widget-chart" data-type="@widget.Widget.Type"
                             data-series="@System.Text.Json.JsonSerializer.Serialize(widget.Series.Select(s => new { label = s.Label, value = s.Value }))"></div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="col-md-3 col-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="avatar mb-3">
                    <span class="avatar-initial rounded bg-label-info"><i class="bx bx-group"></i></span>
                </div>
                <h5 class="mb-1">کاربران</h5>
                <p class="text-muted mb-0">@Model.UserCount کاربر فعال</p>
            </div>
        </div>
    </div>

    @foreach (var (module, count) in Model.Modules)
    {
        <div class="col-md-3 col-6">
            <a href="/App/m/@module.Name" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="avatar mb-3">
                            <span class="avatar-initial rounded bg-label-primary"><i class="bx @module.Icon"></i></span>
                        </div>
                        <h5 class="mb-1">@module.PluralLabel</h5>
                        <p class="text-muted mb-0">@count رکورد</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<div class="modal fade" id="widgetModal" tabindex="-1">
    <div class="modal-dialog">
        <form action="/App/dashboard/widgets/add" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title">افزودن ویجت</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">نوع ویجت</label>
                    <select name="type" class="form-select" id="widgetType">
                        <option value="counter">شمارنده رکوردها</option>
                        <option value="pie">نمودار دایره‌ای (گروه‌بندی)</option>
                        <option value="monthly">روند ماهانه رکوردها</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">ماژول</label>
                    <select name="moduleId" class="form-select" id="widgetModule">
                        @foreach (var module in Model.AllModules)
                        {
                            <option value="@module.Id">@module.PluralLabel</option>
                        }
                    </select>
                </div>
                <div class="mb-3" id="widgetFieldBox" style="display:none">
                    <label class="form-label">فیلد گروه‌بندی</label>
                    <select name="fieldName" class="form-select" id="widgetField"></select>
                </div>
                <div class="mb-3">
                    <label class="form-label">عنوان (اختیاری)</label>
                    <input type="text" name="title" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">انصراف</button>
                <button type="submit" class="btn btn-primary">افزودن</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const picklistFields = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.PicklistFields.ToDictionary(kv => kv.Key, kv => kv.Value.Select(f => new { name = f.Name, label = f.Label }))));

    function refreshWidgetFields() {
        const type = document.getElementById('widgetType').value;
        const moduleId = document.getElementById('widgetModule').value;
        const box = document.getElementById('widgetFieldBox');
        box.style.display = type === 'pie' ? '' : 'none';
        if (type === 'pie') {
            const fields = picklistFields[moduleId] || [];
            document.getElementById('widgetField').innerHTML =
                fields.map(f => `<option value="${f.name}">${f.label}</option>`).join('');
        }
    }
    document.getElementById('widgetType').addEventListener('change', refreshWidgetFields);
    document.getElementById('widgetModule').addEventListener('change', refreshWidgetFields);
    refreshWidgetFields();

    document.querySelectorAll('.widget-chart').forEach(el => {
        const series = JSON.parse(el.dataset.series);
        if (el.dataset.type === 'pie') {
            new ApexCharts(el, {
                chart: { type: 'donut', height: 260, fontFamily: 'inherit' },
                series: series.map(s => s.value),
                labels: series.map(s => s.label),
                legend: { position: 'bottom' }
            }).render();
        } else {
            new ApexCharts(el, {
                chart: { type: 'area', height: 260, toolbar: { show: false }, fontFamily: 'inherit' },
                series: [{ name: 'رکورد', data: series.map(s => s.value) }],
                xaxis: { categories: series.map(s => s.label) },
                colors: ['#696cff'],
                stroke: { width: 2, curve: 'smooth' },
                dataLabels: { enabled: false }
            }).render();
        }
    });
</script>
}
