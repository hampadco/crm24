@using Crm.Web.Services
@model Crm.Web.Areas.Owner.Controllers.OwnerDashboardViewModel
@{
    ViewData["Title"] = "داشبورد مالک";
    ViewData["PanelTitle"] = "پنل مالک CRM24";
}

<partial name="_Alerts" />

<div class="row g-4">
    <div class="col-md-3 col-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="avatar mb-3"><span class="avatar-initial rounded bg-label-primary"><i class="bx bx-buildings"></i></span></div>
                <h5 class="mb-1">@PersianFormattingHelper.ToPersianDigits(Model.TotalTenants.ToString())</h5>
                <p class="text-muted mb-0">کل Tenant ها</p>
                <small class="text-success">@PersianFormattingHelper.ToPersianDigits(Model.NewTenantsLast30Days.ToString()) مورد جدید در ۳۰ روز اخیر</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="avatar mb-3"><span class="avatar-initial rounded bg-label-warning"><i class="bx bx-time-five"></i></span></div>
                <h5 class="mb-1">@PersianFormattingHelper.ToPersianDigits(Model.TrialTenants.ToString())</h5>
                <p class="text-muted mb-0">در دوره آزمایشی</p>
                <small class="text-muted">نرخ تبدیل تریال: @PersianFormattingHelper.ToPersianDigits(Model.TrialConversionPercent.ToString("0.#"))٪</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="avatar mb-3"><span class="avatar-initial rounded bg-label-success"><i class="bx bx-check-shield"></i></span></div>
                <h5 class="mb-1">@PersianFormattingHelper.ToPersianDigits(Model.ActiveTenants.ToString())</h5>
                <p class="text-muted mb-0">اشتراک فعال</p>
                <small class="text-muted">@PersianFormattingHelper.ToPersianDigits(Model.ExpiredTenants.ToString()) منقضی</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="avatar mb-3"><span class="avatar-initial rounded bg-label-info"><i class="bx bx-wallet"></i></span></div>
                <h5 class="mb-1">@PersianFormattingHelper.ToPersianDigits(Model.TotalRevenue.ToString("N0")) تومان</h5>
                <p class="text-muted mb-0">درآمد کل</p>
                <small class="text-success">@PersianFormattingHelper.ToPersianDigits(Model.RevenueLast30Days.ToString("N0")) تومان در ۳۰ روز اخیر</small>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header"><h5 class="mb-0">Tenant های جدید و درآمد ۶ ماه اخیر</h5></div>
            <div class="card-body">
                <div id="monthlyChart"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">آخرین ثبت‌نام‌ها</h5>
                <a asp-controller="Tenants" asp-action="Index" class="btn btn-sm btn-outline-primary">همه</a>
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var tenant in Model.RecentTenants)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <a asp-controller="Tenants" asp-action="Details" asp-route-id="@tenant.Id" class="fw-semibold d-block">@tenant.Name</a>
                            <small class="text-muted">@PersianDateHelper.ToJalaliDate(tenant.CreatedAtUtc)</small>
                        </div>
                        <partial name="_TenantStatusBadge" model="tenant.Status" />
                    </li>
                }
                @if (Model.RecentTenants.Count == 0)
                {
                    <li class="list-group-item text-muted text-center py-4">هنوز ثبت‌نامی وجود ندارد.</li>
                }
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const monthly = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.MonthlyStats.Select(m => new { label = m.Label, tenants = m.NewTenants, revenue = m.Revenue })));

        new ApexCharts(document.querySelector('#monthlyChart'), {
            chart: { type: 'bar', height: 320, toolbar: { show: false }, fontFamily: 'inherit' },
            series: [
                { name: 'Tenant جدید', type: 'column', data: monthly.map(m => m.tenants) },
                { name: 'درآمد (تومان)', type: 'line', data: monthly.map(m => m.revenue) }
            ],
            xaxis: { categories: monthly.map(m => m.label) },
            yaxis: [
                { title: { text: 'Tenant' } },
                { opposite: true, title: { text: 'تومان' }, labels: { formatter: v => v.toLocaleString('fa-IR') } }
            ],
            stroke: { width: [0, 3] },
            colors: ['#696cff', '#71dd37'],
            legend: { position: 'top' }
        }).render();
    </script>
}
