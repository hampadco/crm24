@model Crm.Web.Areas.Owner.Controllers.PlanFormModel
@{
    ViewData["Title"] = Model.Id is null ? "پلن جدید" : "ویرایش پلن";
    ViewData["PanelTitle"] = "پنل مالک CRM24";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bx bx-purchase-tag text-primary me-1"></i> @ViewData["Title"]</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bx bx-right-arrow-alt me-1"></i> بازگشت</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Save" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Description" class="form-label"></label>
                    <input asp-for="Description" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="PriceMonthly" class="form-label"></label>
                    <input asp-for="PriceMonthly" class="form-control" dir="ltr" />
                    <span asp-validation-for="PriceMonthly" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PriceYearly" class="form-label"></label>
                    <input asp-for="PriceYearly" class="form-control" dir="ltr" />
                    <span asp-validation-for="PriceYearly" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MaxUsers" class="form-label"></label>
                    <input asp-for="MaxUsers" class="form-control" dir="ltr" />
                </div>
                <div class="col-md-4">
                    <label asp-for="MaxRecords" class="form-label"></label>
                    <input asp-for="MaxRecords" class="form-control" dir="ltr" />
                </div>
                <div class="col-md-4">
                    <label asp-for="MaxStorageMb" class="form-label"></label>
                    <input asp-for="MaxStorageMb" class="form-control" dir="ltr" />
                </div>
                <div class="col-12">
                    <label asp-for="Features" class="form-label"></label>
                    <textarea asp-for="Features" rows="5" class="form-control"></textarea>
                </div>
                <div class="col-md-4">
                    <label asp-for="SortOrder" class="form-label"></label>
                    <input asp-for="SortOrder" class="form-control" dir="ltr" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsFeatured" class="form-check-input" />
                        <label asp-for="IsFeatured" class="form-check-label"></label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bx bx-save me-1"></i> ذخیره</button>
                <a asp-action="Index" class="btn btn-label-secondary">انصراف</a>
            </div>
        </form>
    </div>
</div>
