@using Crm.Core.Entities
@using Crm.Web.Services
@model List<Crm.Core.Entities.Subscription>
@{
    ViewData["Title"] = "اشتراک‌ها";
    ViewData["PanelTitle"] = "پنل مالک CRM24";
}

<h4 class="mb-4"><i class="bx bx-receipt text-primary me-1"></i> اشتراک‌ها</h4>

<partial name="_Alerts" />

<div class="card">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Tenant</th>
                    <th>پلن</th>
                    <th>شروع</th>
                    <th>پایان</th>
                    <th>مبلغ</th>
                    <th>پرداختی</th>
                    <th>وضعیت</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @if (Model.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-5">اشتراکی ثبت نشده است.</td></tr>
                }
                @foreach (var sub in Model)
                {
                    <tr>
                        <td><a asp-controller="Tenants" asp-action="Details" asp-route-id="@sub.TenantId" class="fw-semibold">@sub.Tenant.Name</a></td>
                        <td>@sub.Plan.Name</td>
                        <td>@PersianDateHelper.ToJalaliDate(sub.StartsAtUtc)</td>
                        <td>@PersianDateHelper.ToJalaliDate(sub.EndsAtUtc)</td>
                        <td>@sub.Amount.ToString("N0") تومان</td>
                        <td>@sub.Payments.Sum(p => p.Amount).ToString("N0") تومان</td>
                        <td>
                            @switch (sub.Status)
                            {
                                case SubscriptionStatus.Active: <span class="badge bg-label-success">فعال</span>; break;
                                case SubscriptionStatus.Expired: <span class="badge bg-label-secondary">منقضی</span>; break;
                                case SubscriptionStatus.Canceled: <span class="badge bg-label-danger">لغو</span>; break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
